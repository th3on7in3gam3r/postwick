# Neon Postgres — use a write-capable Postwick role on the SAME Kerygma project
# (see scripts/neon-postwick-readonly.sql for postwick_app grants). Do not create a separate Neon DB.
DATABASE_URL=

# This Postwick deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Kerygma Social app URL (CTAs / “Powered by”)
NEXT_PUBLIC_KERYGMA_URL=https://kerygmasocial.com

# Operator inbox for /report mailto (optional; defaults to support@kerygmasocial.com)
NEXT_PUBLIC_SUPPORT_EMAIL=support@kerygmasocial.com

# ---------------------------------------------------------------------------
# Clerk (separate Postwick application — never reuse Kerygma’s keys)
# ---------------------------------------------------------------------------
# Local / Development instance:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Production launch checklist (Vercel project `postwick`):
# 1. Clerk Dashboard → Post-Wick app → switch to Production instance
# 2. Copy Production publishable + secret keys into Vercel Production env
#    (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY, sign-in/up URLs)
# 3. Set NEXT_PUBLIC_APP_URL=https://postwick.vercel.app (or your custom domain)
# 4. Enable Bot sign-up protection (CAPTCHA) on the Production instance
#    (Dashboard → Attack protection, or: clerk config patch with captcha_enabled true)
# 5. Redeploy. Confirm /sign-up loads Turnstile (CSP allows challenges.cloudflare.com)
# ---------------------------------------------------------------------------
