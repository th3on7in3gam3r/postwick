# Neon Postgres — use a READ-ONLY role on the SAME Kerygma project
# (see scripts/neon-postwick-readonly.sql). Do not create a separate Neon DB.
# Owner studio edits require a write-capable role (or a limited write role).
DATABASE_URL=

# This Postwick deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Kerygma Social app URL (CTAs / “Powered by”)
NEXT_PUBLIC_KERYGMA_URL=https://kerygmasocial.com

# Operator inbox for /report mailto (optional; defaults to support@kerygmasocial.com)
NEXT_PUBLIC_SUPPORT_EMAIL=support@kerygmasocial.com

# Clerk (separate Postwick application — not Kerygma’s keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
